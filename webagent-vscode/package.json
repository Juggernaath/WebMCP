{
    "name": "webmcp-vscode",
    "displayName": "WebMCP",
    "description": "AI Browser Automation for VS Code & Cursor - Let AI control your browser",
    "version": "1.0.0",
    "publisher": "webmcp",
    "engines": {
        "vscode": "^1.80.0"
    },
    "categories": [
        "AI",
        "Other"
    ],
    "activationEvents": [
        "onStartupFinished"
    ],
    "main": "./out/extension.js",
    "contributes": {
        "commands": [
            {
                "command": "webmcp.start",
                "title": "WebMCP: Start Server"
            },
            {
                "command": "webmcp.stop",
                "title": "WebMCP: Stop Server"
            }
        ],
        "configuration": {
            "title": "WebMCP",
            "properties": {
                "webmcp.port": {
                    "type": "number",
                    "default": 3000,
                    "description": "Port for MCP server"
                }
            }
        }
    },
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "package": "npx vsce package",
        "test": "node ./out/test/runTest.js"
    },
    "devDependencies": {
        "@types/vscode": "^1.80.0",
        "@types/node": "18.x",
        "typescript": "^5.1.3",
        "vsce": "^2.15.0"
    }
}